// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  passwordHash String
  avatarKey    String?

  // 🔹 Stripe + Credits
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  credits              Int     @default(0)
  isAdmin              Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Job       Job[]
  tracks    Track[]
  stories   Story[]
  playlists Playlist[]

  preferenceProfile UserPreferenceProfile?
}

model UserPreferenceProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Structured fields (all optional — users may fill in any subset)
  primaryGoal             String? // sleep | stress_relief | focus | relaxation | comfort | other
  preferredTone           String? // very_soft | calm | neutral | immersive
  pacing                  String? // very_slow | slow | medium
  preferredFormats        String[] @default([]) // ["sleep-story","meditation","classic-asmr","kids-story"]
  likedThemes             String[] @default([])
  dislikedThemes          String[] @default([])
  voicePreference         String? // female | male | no_preference
  directAddressPreference String? // yes | no | subtle
  contentBoundaries       String[] @default([])
  emotionalContext        String?
  desiredOutcome          String?

  // Narrative summary suitable for LLM prompt injection (server-derived; user never edits directly).
  summaryMarkdown String?

  // Raw onboarding answers (free-form JSON) — kept so we can re-derive
  // structured fields if the questionnaire schema evolves.
  onboardingAnswers Json?

  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id          String    @id @default(cuid())
  userId      String
  title       String?
  prompt      String
  preset      String?
  language    String?
  status      JobStatus @default(QUEUED)
  resultUrl   String?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  durationSec Int?
  voiceStyle      String  @default("soft") // "soft" | "whisper"
  voiceGender     String  @default("female") // "female" | "male"
  scriptOverride  String?

  // Credit-refund audit fields
  // ttsStartedAt    — persisted immediately before the first ElevenLabs call.
  //                   NULL means TTS was never attempted for this job.
  //                   Survives serverless function crashes; used by both the
  //                   /complete failure paths and the stale-recovery GET handler
  //                   to decide whether a credit refund is appropriate.
  // creditRefundedAt — set atomically (inside a transaction) the moment a refund
  //                   is issued. Acts as an idempotency gate: no second refund can
  //                   be issued once this is non-NULL, even across concurrent requests
  //                   or function retries.
  ttsStartedAt     DateTime?
  creditRefundedAt DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks Track[]

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([status])
}

model Story {
  id         String   @id @default(cuid())
  userId     String
  title      String
  preset     String   @default("sleep-story")
  language   String?
  scriptText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks Track[]

  @@index([userId, createdAt])
}

model Track {
  id              String   @id @default(cuid())
  userId          String
  jobId           String?
  title           String
  url             String
  durationSeconds Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  job  Job? @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Public Sharing
  isPublic  Boolean @default(false)
  shareSlug String? @unique

  // ✅ Album / Kapitel
  storyId   String?
  partIndex Int? // 1..N (oder 0..N-1, aber konsistent)
  partTitle String?
  story     Story?  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  scriptText String?

  playlistItems PlaylistItem[]

  // Optional aber sehr hilfreich: Reihenfolge eindeutig
  @@unique([storyId, partIndex])
  @@index([userId, createdAt])
  @@index([jobId])
  @@index([storyId, partIndex])
}

model Preset {
  id                 String   @id @default(cuid())
  slug               String   @unique
  label              String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  defaultDurationSec Int?
}

model Playlist {
  id        String         @id @default(cuid())
  userId    String
  name      String
  pinned    Boolean        @default(false)
  position  Int            @default(0)
  coverKey  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PlaylistItem[]

  @@index([userId, pinned, position])
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId, position])
}

enum JobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}
